    {
      "parameters": {
        "jsCode": "// Auth-Token prüfen und Aktion extrahieren\nconst body = $input.first().json.body || $input.first().json;\n\nconst { authToken, action } = body;\n\n// Timing-Safe-Vergleich ist in diesem Kontext nicht erreichbar;\n// einfacher String-Vergleich reicht für MVP (TLS schützt den Transport)\nconst expectedHash = $env.AUTH_HASH;\n\nif (!expectedHash) {\n  return [{ json: { ok: false, fehler: 'Server-Konfigurationsfehler: AUTH_HASH fehlt', statusCode: 500 } }];\n}\n\nif (!authToken || authToken !== expectedHash) {\n  return [{ json: { ok: false, fehler: 'Nicht autorisiert', statusCode: 401 } }];\n}\n\nconst erlaubteAktionen = ['list', 'create', 'update', 'deactivate', 'today'];\nif (!action || !erlaubteAktionen.includes(action)) {\n  return [{ json: { ok: false, fehler: `Unbekannte Aktion: ${action}`, statusCode: 400 } }];\n}\n\n// Payload für nachfolgende Nodes durchreichen\nreturn [{ json: { ok: true, action, payload: body } }];\n"
      },
