    {
      "parameters": {
        "jsCode": "// Update-Felder vorbereiten\nconst payload = $input.first().json.payload;\n\nconst kursId = payload.kursId ? String(payload.kursId).trim() : '';\nif (!kursId) {\n  return [{ json: { ok: false, fehler: 'Kurs-ID für Update erforderlich', statusCode: 400 } }];\n}\n\nconst name = payload.name ? String(payload.name).replace(/[<>\"']/g, '').trim().substring(0, 100) : '';\nconst notiz = payload.notiz !== undefined ? String(payload.notiz).replace(/[<>\"']/g, '').trim().substring(0, 200) : null;\n\nreturn [{\n  json: {\n    ok: true,\n    kursId,\n    name,\n    notiz\n  }\n}];\n"
      },
