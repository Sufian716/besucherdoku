    {
      "parameters": {
        "jsCode": "// Alle Kurse als JSON-Array aufbereiten\nconst kurse = $input.all().map(item => item.json);\nreturn [{ json: { ok: true, kurse } }];\n"
      },
      "id": "b2c3d4e5-0002-0002-0002-000000000006",
      "name": "Liste aufbereiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 100]
    },
    {
      "parameters": {
        "jsCode": "// Neuen Kurs anlegen: Felder validieren, Kurs-ID erzeugen falls leer\nconst payload = $input.first().json.payload;\n\nconst name = payload.name ? String(payload.name).replace(/[<>\"']/g, '').trim().substring(0, 100) : '';\nif (!name) {\n  return [{ json: { ok: false, fehler: 'Kursname ist Pflichtfeld', statusCode: 400 } }];\n}\n\n// Kurs-ID: aus Name ableiten wenn leer (Leerzeichen → Bindestrich, Umlaut-Ersatz, Großbuchstaben)\nlet kursId = payload.kursId ? String(payload.kursId).trim() : '';\nif (!kursId) {\n  kursId = name\n    .toLowerCase()\n    .replace(/ä/g, 'ae').replace(/ö/g, 'oe').replace(/ü/g, 'ue').replace(/ß/g, 'ss')\n    .replace(/[^a-z0-9]+/g, '-')\n    .replace(/^-+|-+$/g, '')\n    .substring(0, 30);\n}\n\n// Format-Check\nif (!/^[A-Za-z0-9\\-_]{1,50}$/.test(kursId)) {\n  return [{ json: { ok: false, fehler: 'Kurs-ID ungültig (erlaubt: Buchstaben, Zahlen, Bindestrich, Unterstrich)', statusCode: 400 } }];\n}\n\nconst notiz = payload.notiz ? String(payload.notiz).replace(/[<>\"']/g, '').trim().substring(0, 200) : '';\n\nconst now = new Date();\nconst erstelltAm = now.toLocaleDateString('de-DE', {\n  timeZone: 'Europe/Berlin',\n  day: '2-digit', month: '2-digit', year: 'numeric'\n});\n\nreturn [{\n  json: {\n    ok: true,\n    'Kurs-ID': kursId,\n    'Name': name,\n    'Aktiv': 'ja',\n    'Erstellt-am': erstelltAm,\n    'Notiz': notiz\n  }\n}];\n"
      },
