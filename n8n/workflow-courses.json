        "jsCode": "// Nur heutige Einträge zurückgeben\nconst heute = new Date().toLocaleDateString('de-DE', {\n  timeZone: 'Europe/Berlin',\n  day: '2-digit', month: '2-digit', year: 'numeric'\n});\n\nconst heut = $input.all()\n  .filter(item => item.json['Datum'] === heute)\n  .map(item => item.json);\n\nreturn [{ json: { ok: true, eintraege: heut, datum: heute } }];\n"
