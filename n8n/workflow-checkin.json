    {
      "parameters": {
        "jsCode": "// Datum und Zeit im deutschen Format aufbereiten\nconst now = new Date();\nconst tz = 'Europe/Berlin';\n\nconst datum = now.toLocaleDateString('de-DE', {\n  timeZone: tz,\n  day: '2-digit',\n  month: '2-digit',\n  year: 'numeric'\n});\n\nconst zeit = now.toLocaleTimeString('de-DE', {\n  timeZone: tz,\n  hour: '2-digit',\n  minute: '2-digit'\n});\n\nconst timestamp = now.toISOString();\n\nconst validierung = $('Eingaben validieren').first().json;\nconst kursInfo = $('Kurs prüfen').first().json;\n\nreturn [{\n  json: {\n    'TN-ID': validierung.tnId,\n    'Name': validierung.tnName,\n    'Kurs-ID': kursInfo.kursId,\n    'Kurs-Name': kursInfo.kursName,\n    'Datum': datum,\n    'Zeit': zeit,\n    'Timestamp': timestamp\n  }\n}];\n"
      },
