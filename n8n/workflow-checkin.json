    {
      "parameters": {
        "jsCode": "// Eingaben validieren: Shared-Key, TN-ID, Kurs-ID\nconst body = $input.first().json.body || $input.first().json;\n\nconst { checkinKey, tnId, tnName, kursId } = body;\n\n// Shared-Key prüfen (Env-Variable CHECKIN_KEY muss gesetzt sein)\nconst expectedKey = $env.CHECKIN_KEY;\nif (!expectedKey) {\n  throw new Error('Server-Konfigurationsfehler: CHECKIN_KEY fehlt');\n}\nif (!checkinKey || checkinKey !== expectedKey) {\n  return [{ json: { ok: false, fehler: 'Ungültiger Checkin-Schlüssel', statusCode: 403 } }];\n}\n\n// TN-ID: Pflichtfeld, nur alphanumerisch + Bindestrich/Unterstrich\nif (!tnId || typeof tnId !== 'string' || !/^[A-Za-z0-9\\-_]{1,50}$/.test(tnId.trim())) {\n  return [{ json: { ok: false, fehler: 'Ungültige oder fehlende TN-ID', statusCode: 400 } }];\n}\n\n// Kurs-ID: Pflichtfeld, selbes Muster\nif (!kursId || typeof kursId !== 'string' || !/^[A-Za-z0-9\\-_]{1,50}$/.test(kursId.trim())) {\n  return [{ json: { ok: false, fehler: 'Ungültige oder fehlende Kurs-ID', statusCode: 400 } }];\n}\n\n// Bereinigter Name (optional, max. 100 Zeichen)\nconst sauberName = tnName ? String(tnName).replace(/[<>\"'&]/g, '').trim().substring(0, 100) : '';\n\nreturn [{\n  json: {\n    ok: true,\n    tnId: tnId.trim(),\n    tnName: sauberName,\n    kursId: kursId.trim()\n  }\n}];\n"
      },
