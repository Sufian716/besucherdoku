    {
      "parameters": {
        "jsCode": "// Prüfen ob Kurs existiert UND aktiv ist\nconst kursId = $('Eingaben validieren').first().json.kursId;\nconst kurse = $input.all();\n\nconst gefunden = kurse.find(item =>\n  item.json['Kurs-ID'] === kursId &&\n  String(item.json['Aktiv']).toLowerCase() === 'ja'\n);\n\nif (!gefunden) {\n  return [{\n    json: {\n      ok: false,\n      fehler: `Kurs \"${kursId}\" nicht gefunden oder nicht aktiv`,\n      statusCode: 404\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ok: true,\n    kursId: gefunden.json['Kurs-ID'],\n    kursName: gefunden.json['Name']\n  }\n}];\n"
      },
